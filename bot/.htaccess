# Deny all web access to bot directory
# The bot runs as a separate Node.js process, not through the web server

# Apache 2.4+
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# Custom error page (optional)
ErrorDocument 403 "Access Denied - This directory is for bot operations only"
