# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here
DISCORD_GUILD_ID=your_server_id_here

# Vote Channel Configuration
VOTE_CHANNEL_ID=channel_id_where_votes_are_posted

# Website Integration
WEBSITE_URL=https://yoursite.com
WEBHOOK_SECRET=random_secret_for_webhook_authentication

# Data Directory (relative to bot folder)
DATA_DIR=../data

# Bot Settings
VOTE_DURATION_HOURS=24
ENABLE_EARLY_CLOSE=true
ENABLE_VOTE_REMINDERS=true
REMINDER_HOURS_BEFORE_END=2
