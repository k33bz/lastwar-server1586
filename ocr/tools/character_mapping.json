{
  "metadata": {
    "version": "1.0.0",
    "created": "2025-10-12",
    "description": "Character substitution mapping for OCR corrections",
    "source": "Analysis of 23 manually verified training examples",
    "engines_tested": ["tesseract", "easyocr"]
  },
  "common_substitutions": {
    "description": "Most common OCR misreads and their corrections",
    "mappings": [
      {
        "correct": "ღ",
        "common_misreads": ["o", "q", "g", "9"],
        "character_type": "special_symbol",
        "unicode": "U+10E6",
        "name": "Georgian letter ghan (heart symbol)",
        "example": "ULoveGucciiღ (STR8)"
      },
      {
        "correct": "ʚ",
        "common_misreads": ["3", "E", "e", "c"],
        "character_type": "special_bracket",
        "unicode": "U+029A",
        "name": "Latin small letter closed open E",
        "example": "ʚᴸᵘᶰᵃɞ (86KO)"
      },
      {
        "correct": "ɞ",
        "common_misreads": ["3", "E", "e", "o"],
        "character_type": "special_bracket",
        "unicode": "U+025E",
        "name": "Latin small letter closed reversed open E",
        "example": "ʚᴸᵘᶰᵃɞ (86KO)"
      },
      {
        "correct": "ᓚᘏᗢ",
        "common_misreads": ["cat", "^^^", "|||", "123", ""],
        "character_type": "emoji_composite",
        "unicode": "U+14DA U+1613 U+15E2",
        "name": "Canadian Aboriginal Syllabics cat face",
        "example": "쿠치나 ᓚᘏᗢ (UvvU)",
        "note": "Often completely dropped by OCR"
      },
      {
        "correct": "ᴸ",
        "common_misreads": ["L", "l", "I", "1", ""],
        "character_type": "superscript",
        "unicode": "U+1D38",
        "name": "Modifier letter capital L",
        "example": "ʚᴸᵘᶰᵃɞ (86KO)"
      },
      {
        "correct": "ᵘ",
        "common_misreads": ["u", "v", "o", ""],
        "character_type": "superscript",
        "unicode": "U+1D58",
        "name": "Modifier letter small u",
        "example": "ʚᴸᵘᶰᵃɞ (86KO)"
      },
      {
        "correct": "ᶰ",
        "common_misreads": ["n", "m", ""],
        "character_type": "superscript",
        "unicode": "U+1DB0",
        "name": "Modifier letter small n with retroflex hook",
        "example": "ʚᴸᵘᶰᵃɞ (86KO)"
      },
      {
        "correct": "ᵃ",
        "common_misreads": ["a", "o", ""],
        "character_type": "superscript",
        "unicode": "U+1D43",
        "name": "Modifier letter small a",
        "example": "ʚᴸᵘᶰᵃɞ (86KO)"
      }
    ]
  },
  "korean_patterns": {
    "description": "Korean character OCR patterns and common issues",
    "issues": [
      {
        "issue": "Complete character drop",
        "frequency": "high",
        "example": "잔인한노니 → 노니",
        "solution": "Use Korean-specific OCR model"
      },
      {
        "issue": "Partial syllable recognition",
        "frequency": "medium",
        "example": "쿠치나 → 크치나",
        "solution": "Post-process with Korean dictionary"
      },
      {
        "issue": "Mixed with ASCII spaces",
        "frequency": "low",
        "example": "잔인한노니 Noni → correct",
        "solution": "Preserve space between Korean and ASCII"
      }
    ],
    "common_korean_chars": {
      "쿠": ["크", "투"],
      "치": ["티", "치"],
      "나": ["다", "라"],
      "잔": ["잠", "간"],
      "인": ["임", "일"],
      "한": ["할", "함"],
      "노": ["도", "로"],
      "니": ["리", "디"],
      "최": ["최", "회"],
      "사": ["아", "자"],
      "령": ["령", "명"],
      "관": ["관", "간"]
    }
  },
  "numeric_patterns": {
    "description": "Common numeric OCR errors",
    "mappings": [
      {
        "correct": "0",
        "common_misreads": ["O", "o", "Q"],
        "context": "In usernames and IDs"
      },
      {
        "correct": "1",
        "common_misreads": ["I", "l", "|"],
        "context": "In usernames and IDs"
      },
      {
        "correct": "5",
        "common_misreads": ["S", "s"],
        "context": "In usernames"
      },
      {
        "correct": "8",
        "common_misreads": ["B"],
        "context": "In alliance tags"
      }
    ]
  },
  "context_rules": {
    "description": "Context-based correction rules using alliance tags",
    "rules": [
      {
        "alliance_tag": "UvvU",
        "expected_pattern": "korean_chars + emoji",
        "correction": "If no Korean detected, likely OCR failure"
      },
      {
        "alliance_tag": "86KO",
        "expected_pattern": "special_brackets + superscripts",
        "correction": "Expect ʚ and ɞ brackets with superscript between"
      },
      {
        "alliance_tag": "STR8",
        "expected_pattern": "ascii + heart_symbol",
        "correction": "Look for ღ at end of name"
      },
      {
        "alliance_tag": "NKOT",
        "expected_pattern": "korean + space + ascii",
        "correction": "Should have both Korean and ASCII parts"
      },
      {
        "alliance_tag": "1985",
        "expected_pattern": "korean_only",
        "correction": "Pure Korean name, no ASCII expected"
      }
    ]
  },
  "confidence_indicators": {
    "description": "Indicators of low OCR confidence requiring review",
    "low_confidence_signals": [
      "Contains only ASCII when tag suggests Korean",
      "Missing expected special characters (ღ, ʚ, ɞ)",
      "Unusual character combinations (multiple symbols)",
      "Length significantly different from historical average",
      "Contains obvious OCR artifacts (|||, ^^^, etc.)"
    ],
    "high_confidence_signals": [
      "Matches historical R5 name for this alliance",
      "Contains expected character types for this tag",
      "Multiple OCR engines agree on result",
      "All characters are in expected Unicode ranges",
      "Length matches typical R5 name pattern (5-20 chars)"
    ]
  },
  "engine_specific_notes": {
    "tesseract": {
      "strengths": ["ASCII", "numbers"],
      "weaknesses": ["Korean", "emojis", "superscripts"],
      "recommended_config": "lang=eng+kor, psm=7, oem=3"
    },
    "easyocr": {
      "strengths": ["Korean", "mixed scripts"],
      "weaknesses": ["special Unicode", "emojis"],
      "recommended_config": "lang=['en', 'ko'], gpu=True"
    },
    "paddleocr": {
      "strengths": ["Korean", "Chinese", "general Unicode"],
      "weaknesses": ["rare emojis", "superscripts"],
      "recommended_config": "lang='korean', use_angle_cls=True"
    }
  }
}
