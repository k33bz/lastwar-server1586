# Git Ignore File
# Files and directories listed here will NOT be committed to GitHub

# Sensitive Information - NEVER COMMIT
.env
*.env
config.json
credentials.json
secrets.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

