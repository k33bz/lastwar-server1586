# FTP Deployment Ignore File
# Files and directories listed here will NOT be uploaded to the FTP server

# Development and Documentation
/README.md
/CLAUDE.md
/LICENSE
/*.md
/CONTRIBUTORS.md
/KIRO-GITHUB-TEST.md
/test-coauthor.md
/ISSUE_COMPLETION_SUMMARY.md
/setup-kiro-git.bat
/docs/
!index.html

# Scripts and Tools (deployment scripts not needed on server)
/scripts/
/.vscode/
/.idea/

# Version Control
/.git/
/.gitignore
/.gitattributes
/.github/

# CI/CD and Training Files
/tesseract_training/
/ocr/
/.claude/
/.kiro/
/CICD-SETUP.md

# Admin System - Exclude development/test files only
# Note: admin/.env is generated during deployment from GitHub Secrets and MUST be deployed
!admin/.env
admin/.claude/
admin/.vscode/
admin/test*.php
admin/test*.py
admin/compare_emails.php
admin/debug_email_content.php
admin/*.backup
admin/backups/
admin/*.md
admin/dashboard_with_rotation.php

# Test Tokens - NEVER DEPLOY
test-*.txt
test-token-*.txt
admin/test-*.txt
admin/tests/test-results.json

# Backup and deleted files
*.del
*.js.del

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.env
*.egg-info/

# Node.js (if ever added)
node_modules/
npm-debug.log
yarn-error.log
package-lock.json

# Images - Exclude source files only, deploy production images
*.psd
*.ai
/images/alliance_cards/*.png
/images/alliance_cards/processed/
/images/server_rankings/*.png
/images/server_rankings/processed/
/images/src/

# Backup and Temporary Files
*.bak
*.tmp
*.swp
*~
.DS_Store
Thumbs.db

# IDE and Editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Log Files
*.log

# Configuration (exclude .ftpignore but INCLUDE .htaccess)
.ftpignore
!.htaccess
