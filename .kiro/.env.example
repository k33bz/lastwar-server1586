# Kiro GitHub Integration
# Copy this to .kiro/.env and fill in your values

# GitHub Personal Access Token (keep this secret!)
GITHUB_TOKEN=your_github_token_here

# Repository Information
GITHUB_OWNER=k33bz
GITHUB_REPO=lastwar-server1586
GITHUB_EMAIL=your-email@example.com

# Optional: Default commit settings
GITHUB_DEFAULT_BRANCH=main
GITHUB_AUTO_COMMIT=true