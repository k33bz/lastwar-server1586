# JWT Secret Key (generate a strong random key, at least 64 characters)
# You can generate one with: openssl rand -base64 64
SECRET_KEY=your-long-random-secret-key-here-replace-with-actual-secret

# SMTP Configuration - cPanel Email
SMTP_HOST=example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password-here
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=Last War 1586

# Application Configuration
APP_URL=https://www.example.com
ADMIN_EMAIL=admin@example.com

# Token Expiry Times (in seconds)
MAGIC_LINK_EXPIRY=600        # 10 minutes
SESSION_TOKEN_EXPIRY=3600    # 1 hour
REFRESH_TOKEN_EXPIRY=604800  # 7 days

# Token Rotation Configuration
TOKEN_ROTATION_ENABLED=true
TOKEN_ROTATION_THRESHOLD=0.5 # Rotate when 50% of lifetime remains
AUTO_CLEANUP_ENABLED=true    # Enable automatic token cleanup

# JWT Secret Key Rotation Configuration (v1.0.0)
AUTO_KEY_ROTATION_ENABLED=true
KEY_ROTATION_INTERVAL_DAYS=30    # Rotate secret key every 30 days
KEY_ROTATION_GRACE_PERIOD=300    # 5 minutes grace period for old key

# Security Monitoring Configuration (v1.0.0)
SECURITY_MONITORING_ENABLED=true
RATE_LIMITING_ENABLED=true
AUTO_IP_BLOCKING_ENABLED=true
MFA_ENFORCEMENT_ENABLED=false   # Set to true to require MFA for all admins

# Environment (development, production)
APP_ENV=production
