# JWT Secret Key (generate a strong random key, at least 64 characters)
# You can generate one with: openssl rand -base64 64
SECRET_KEY=your-long-random-secret-key-here-replace-with-actual-secret

# SMTP Configuration - cPanel Email
SMTP_HOST=example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password-here
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=Last War 1586

# Application Configuration
APP_URL=https://www.example.com
ADMIN_EMAIL=admin@example.com

# Token Expiry Times (in seconds)
MAGIC_LINK_EXPIRY=600        # 10 minutes
SESSION_TOKEN_EXPIRY=3600    # 1 hour

# Environment (development, production)
APP_ENV=production
