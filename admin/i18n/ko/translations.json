{
  "help": {
    "president_approvals": {
      "title": "대통령 선거 승인 절차에 대한 도움 요청",
      "sections": {
        "overview": {
          "title": "개요 (Overview)",
          "intro": "서버의 <strong>대표자</strong>로서, 여러분은 이사회 구성원들이 제출한 투표 제안을 검토하고 승인할 책임이 있습니다. 이는 서버의 거버넌스 체계에서 매우 중요한 역할입니다.",
          "responsibilities": {
            "title": "귀하의 책임 사항:",
            "items": [
              "모든 들어오는 투표 제안을 검토하십시오.",
              "잘 구성되고 합법적인 제안들을 승인하십시오.",
              "명확하지 않거나 부적절하며, 투표가 필요 없는 제안들은 거부하세요.",
              "제안을 거절할 때는 명확한 피드백을 제공하세요.",
              "최대한 빠른 시간 내에(가능하다면 12시간 이내에) 조치를 취해 주세요."
            ]
          },
          "auto_approval_note": "자동 승인 시스템: 제안서를 12시간 이내에 검토하지 않으면 자동으로 승인되며, 투표가 진행됩니다. 이를 통해 업무의 지연을 방지할 수 있지만, 해당 페이지를 정기적으로 확인하는 것이 중요합니다."
        },
        "proposal_table": {
          "title": "제안 내용을 이해하기 (Understanding the Proposal Table)",
          "intro": "이 표에는 귀하의 검토가 필요한 모든 보류 중인 투표 제안 사항들이 나와 있습니다.",
          "columns": {
            "submitted_by": "<strong>제출자:</strong> 제안서를 작성한 위원회 위원 (이메일 주소로 표시)",
            "title": "<strong>제목:</strong> 투표 제목은 명확하고 간결해야 합니다.",
            "description": "<strong>설명:</strong> 현재 투표 대상에 대한 상세한 설명입니다. 내용이 잘렸다면 클릭하여 확장하십시오.",
            "category": "<strong>카테고리:</strong> 투표의 유형 (규칙 변경, 동맹 분쟁, 영토 결정, 이벤트 계획, 기타)",
            "submitted_at": "<strong>제출 시간:</strong> 제안서가 작성된 시점",
            "time_remaining": "<strong>남은 시간:</strong> 자동 승인까지의 카운트다운 (제출 후 12시간)",
            "actions": "<strong>작업 내용:</strong> “승인(Approve)” 또는 “거부(Reject)” 버튼을 클릭합니다."
          },
          "priority_warning": "우선순위 검토: 남은 시간이 적은 제안들부터 먼저 검토해야 합니다. “긴급(URGENT)” 표시가 되어 있고 남은 시간이 2시간 미만인 경우에는 해당 제안을 우선적으로 처리하세요."
        },
        "how_to_approve": {
          "title": "제안서를 승인하는 방법",
          "steps_title": "단계별 승인 절차:",
          "steps": [
            "<strong>주의 깊게 읽어주세요:</strong> 제목, 설명, 그리고 카테고리를 확인하십시오.",
            "<strong>합법성 평가:</strong> 이 결정은 위원회 차원에서 내려진 것인가요? 무엇에 대해 투표를 하는지 명확하게 알 수 있나요?",
            "<strong>시기 고려: 지금이 이 투표를 실시하기에 적절한 시간인가요? (예: 주요 이벤트가 진행되지 않는 시기 등)",
            "<strong>“승인”을 클릭하세요:</strong> 제안이 기준을 충족하는 경우에만 가능합니다.",
            "<strong>확인:</strong> 성공 메시지가 표시될 것입니다.",
            "<strong>자동 작업:</strong> 투표가 즉시 생성되며, 모든 이사회 구성원에게 개인 메시지(DM)가 전송됩니다."
          ],
          "after_approval": {
            "title": "승인이 완료된 후에는 어떤 일이 일어나나요?",
            "items": [
              "투표 기능은 디스코드(Discord) 봇 시스템 내에서 구현됩니다.",
              "모든 7명의 위원회 위원들은 투표 세부 정보가 담긴 디스코드(Discord) 개인 메시지를 받습니다.",
              "24시간 동안의 투표 기간이 시작되었습니다.",
              "제안이 귀하의 대기 중인 항목 목록에서 삭제되었습니다.",
              "제출자에게 승인 사실이 알려집니다."
            ]
          },
          "criteria_title": "승인 기준:",
          "criteria": [
            "✅ 제목과 설명이 명확하고 구체적입니다.",
            "✅ 합법적인 이사회 수준의 결정",
            "✅ 기존의 규칙이나 투표 내용에서 이미 다루어지지 않은 항목들입니다.",
            "✅ 적절한 카테고리가 선택되었습니다.",
            "✅ 적절한 시기(주요 이벤트나 분쟁이 발생하지 않는 기간에)"
          ]
        }
      }
    }
  },
