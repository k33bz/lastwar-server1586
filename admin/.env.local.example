# Local Development Environment Configuration
# Copy this file to .env for local development

# JWT Secret Key (use a dev key or copy from production .env)
SECRET_KEY=dev-secret-key-change-this-for-testing

# SMTP Configuration - COPY THESE FROM YOUR PRODUCTION .env
# This allows emails to send from localhost using production mail server
SMTP_HOST=COPY_FROM_PRODUCTION_ENV
SMTP_PORT=COPY_FROM_PRODUCTION_ENV
SMTP_USER=COPY_FROM_PRODUCTION_ENV
SMTP_PASS=COPY_FROM_PRODUCTION_ENV
SMTP_FROM=COPY_FROM_PRODUCTION_ENV
SMTP_FROM_NAME="Last War 1586 (Local Dev)"

# Application Configuration - LOCALHOST SETTINGS
# These should point to your local server, NOT production
APP_URL=http://localhost:8080
ADMIN_EMAIL=admin@localhost

# Token Expiry Times (in seconds)
MAGIC_LINK_EXPIRY=600        # 10 minutes
SESSION_TOKEN_EXPIRY=3600    # 1 hour

# Environment
APP_ENV=development

# =====================================================
# INSTRUCTIONS FOR LOCAL DEVELOPMENT:
# =====================================================
# 1. Copy this file to .env:
#    cp .env.local.example .env
#
# 2. Open your production .env and COPY ONLY the SMTP values:
#    - Replace SMTP_HOST=COPY_FROM_PRODUCTION_ENV with actual value
#    - Replace SMTP_PORT=COPY_FROM_PRODUCTION_ENV with actual value
#    - Replace SMTP_USER=COPY_FROM_PRODUCTION_ENV with actual value
#    - Replace SMTP_PASS=COPY_FROM_PRODUCTION_ENV with actual value
#    - Replace SMTP_FROM=COPY_FROM_PRODUCTION_ENV with actual value
#
# 3. KEEP these as localhost values (DO NOT change):
#    - APP_URL=http://localhost:8080
#    - ADMIN_EMAIL=admin@localhost
#    - APP_ENV=development
#
# 4. Start your local server:
#    cd C:\Users\k33bz\OneDrive\git\Server1586-clean
#    php -S localhost:8080 -t .
#
# 5. Access admin panel:
#    http://localhost:8080/admin/login.php
#
# RESULT: Emails will send via production SMTP, but magic links
#         will point to localhost:8080 for local testing
