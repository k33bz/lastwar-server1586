# Server Configuration (Multi-Server Support v3.8.0+)
#
# Each Last War server deploys its own copy of the public site
# with these environment variables configured for their specific server.
#
# Copy this file to .env.local and configure for your server:
#   cp .env.example .env.local

# Server ID (required)
# The Last War server identifier (e.g., '1586', '9999', 'ORCE', etc.)
# This is used to filter API data to show only your server's alliances
VITE_SERVER_ID=1586

# Server Name (optional)
# Human-readable name displayed in the UI
# Defaults to "Server {ID}" if not specified
VITE_SERVER_NAME=Server 1586

# API Base URL (optional)
# Base URL for API endpoints if different from default
# Leave empty for relative paths (recommended)
# Example: https://api.lastwar1586.online
VITE_API_BASE_URL=
